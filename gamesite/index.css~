*{box-sizing: border-box;}
html {
    margin: 0;
    height: 100vh;
    width: 100vw;
}
body {
    background-color: lightgray;
    height: 100vh;
    width: 100vw;
    margin: 0;
}

#applications {
    display: grid;
    width: 100%;
    height: 100%;
    max-width: 100vw;
    gap: 1em;
    padding: 1em;
    grid-template-columns: repeat(auto-fit, minmax(250px, max-content));
    grid-auto-rows: max-content;
    scrollbar-gutter: stable;
    overflow: scroll;
    overflow-x: hidden;
}

.app {
    overflow: hidden;
    background: black;
    color: white;
    border-radius: 0.5em;
    height: fit-content;
    display: flex;
    flex-direction: column;
    align-items: center;
}
.app>img{
    max-width: 20em;
}
.app>h1{
    margin: 0;
    font-family: sans-serif;
}

.app>img{
    width: 100%;
    object-fit: cover;
}
